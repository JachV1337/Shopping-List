<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Shopping_List.Pages.AddItems"
             Title="AddItems">
    <VerticalStackLayout>
        <Label 
            Text="Add Product"
            FontSize="32"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
        <Editor
            x:Name="ProductName"
            Placeholder="Product Name"
            VerticalOptions="Center" 
            HorizontalOptions="Center" 
            WidthRequest="200"/>
        <Button
            Text="Add"
            WidthRequest="75"
            Margin="20"
            VerticalOptions="Center" 
            HorizontalOptions="Center"
            Command="{Binding AddItemCommand}"
            CommandParameter="{Binding Text, Source={x:Reference ProductName}}" />
    </VerticalStackLayout>
</ContentPage>