<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Shopping_List.MainPage"
             x:Name="Main">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">
            <Label Text="Products to buy"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <CollectionView ItemsSource="{Binding ShoppingItems}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <HorizontalStackLayout Spacing="15" 
                                              Padding="10"
                                              HorizontalOptions="Center">
                            <HorizontalStackLayout.GestureRecognizers>
                                <SwipeGestureRecognizer Direction="Left"
                                                        Command="{Binding BindingContext.RemoveItemCommand, Source={x:Reference Name=Main}}" CommandParameter="{Binding .}">
                                </SwipeGestureRecognizer>
                            </HorizontalStackLayout.GestureRecognizers>
                            <Label Text="{Binding Name}" 
                                   FontSize="16"
                                   VerticalOptions="Center"
                                   MinimumWidthRequest="150" 
                                   >
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsChecked}" Value="True">
                                        <Setter Property="TextColor" Value="Green"/>
                                        <Setter Property="FontAttributes" Value="Bold"/>
                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                        <Setter Property="FontAttributes" Value="Italic"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsChecked}" Value="False">
                                        <Setter Property="TextColor" Value="White"/>
                                        <Setter Property="FontAttributes" Value="None"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <CheckBox IsChecked="{Binding IsChecked}"
                                      VerticalOptions="Center"
                                      Command="{Binding Source={x:Reference Main}, Path=BindingContext.ToggleItemCheckedCommand}" CommandParameter="{Binding .}"/>
                        </HorizontalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <VerticalStackLayout VerticalOptions="Center"
                                   HorizontalOptions="Center">
                <HorizontalStackLayout>
                    <ProgressBar Progress="{Binding CheckedProgress}"  Margin="0,0,0,40" WidthRequest="200" ProgressColor="AliceBlue"></ProgressBar>
                    <Label Text="{Binding CheckedProgress, StringFormat='{0:P0}'}" FontSize="16" VerticalOptions="Center" Margin="10,0,0,40"></Label>
                </HorizontalStackLayout>
                <Button Text="Delete all" Command="{Binding ClearItemsCommand}"></Button>
                <HorizontalStackLayout HorizontalOptions="Center" Padding="10">
                    <Button Text="Export" Command="{Binding ExportItemsCommand}"></Button>
                    <Button Text="Import" Command="{Binding ImportitemsCommand}" Margin="10,0,0,0"></Button>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
